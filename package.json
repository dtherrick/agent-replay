{
  "name": "@daherrick-splunk/agent-replay",
  "version": "0.1.0",
  "description": "Replay and step through AI agent conversations from Cursor, Gemini CLI, and more",
  "type": "module",
  "bin": {
    "agent-replay": "bin/agent-replay.mjs"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node esbuild.server.mjs",
    "build:client": "tsc -b && vite build",
    "build:server": "node esbuild.server.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "start": "node bin/agent-replay.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.2.0",
    "express": "^5.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vitest": "^4.0.18"
  }
}
